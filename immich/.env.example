# Pin a specific release for stable upgrades; bump deliberately.
# See https://github.com/immich-app/immich/releases
IMMICH_VERSION=release

# Where the photo library lives (on the HDD mirror).
UPLOAD_LOCATION=/mnt/data/immich/library

# Where Postgres stores its data (also on the HDD mirror).
DB_DATA_LOCATION=/mnt/data/immich/postgres

# Database credentials. Generate a strong password (e.g. `openssl rand -hex 24`).
DB_PASSWORD=changeme
DB_USERNAME=postgres
DB_DATABASE_NAME=immich

# Timezone (uncomment and set if /etc/localtime mapping is insufficient)
# TZ=America/New_York
