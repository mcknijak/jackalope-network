# Install at /etc/restic.env (mode 600, owned by root).
# This file holds the encryption password and B2 credentials, so treat
# it like an SSH private key.

# Encryption password for both restic repositories.
# Generate with: openssl rand -base64 32
# WRITE THIS DOWN SOMEWHERE OFFLINE. Without it the backups are unrecoverable.
RESTIC_PASSWORD=changeme

# Local repository on the external USB drive (label `homelab-backup`,
# mounted at /mnt/backup via /etc/fstab).
RESTIC_REPOSITORY_USB=/mnt/backup/restic

# Backblaze B2 repository.
# Create an application key scoped to a single bucket at
# https://secure.backblaze.com/app_keys.htm
RESTIC_REPOSITORY_B2=b2:jackalope-homelab-backup:/
B2_ACCOUNT_ID=
B2_ACCOUNT_KEY=
