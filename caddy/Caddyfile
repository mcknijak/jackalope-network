# Global options
{
	email you@jackalope.network

	# Default ACME challenge for every site below: DNS-01 via Porkbun.
	# This works without inbound ports being open, which fits the
	# Tailscale-only access pattern.
	acme_dns porkbun {
		api_key {env.PORKBUN_API_KEY}
		api_secret_key {env.PORKBUN_API_SECRET_KEY}
	}
}

# ── Root: public welcome page ────────────────────────────────────────────────
# jackalope.network apex serves the static landing built from /srv/welcome.
# This is the one always-public surface besides photos.jackalope.network.
# Plan to expose it via Tailscale Funnel (same daemon as photo sharing,
# TCP passthrough so Caddy keeps terminating TLS). See README step 13 and
# docs/why-tailscale.md. Until that's wired up, this site block still works
# on the tailnet.
jackalope.network {
	root * /srv/welcome
	encode zstd gzip
	file_server
	header {
		# Defense-in-depth headers for a static page.
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "interest-cohort=()"
	}
}

# ── Tailnet probe ────────────────────────────────────────────────────────────
# Static 200 used by the welcome page to detect whether the browser can reach
# the tailnet. DNS for probe.jackalope.network points at the tailnet IP, so a
# successful fetch implies the client is on the tailnet. CORS is opened to
# the welcome page's origin so the cross-origin fetch can read the response.
probe.jackalope.network {
	@welcome header Origin "https://jackalope.network"
	header @welcome Access-Control-Allow-Origin "https://jackalope.network"
	header Cache-Control "no-store"
	respond /ok 200 {
		body "ok"
	}
	respond 404
}

# ── Apps (tailnet-only) ──────────────────────────────────────────────────────

# Photos: Immich
immich.jackalope.network {
	reverse_proxy immich_server:2283
}

# Video: Jellyfin
jellyfin.jackalope.network {
	reverse_proxy jellyfin:8096
}

# Obsidian sync: CouchDB
# CouchDB needs CORS headers for the LiveSync plugin; CouchDB sets these
# itself once configure-cors.sh has been run, so Caddy just proxies.
couchdb.jackalope.network {
	reverse_proxy couchdb:5984
}

# Matrix homeserver (client API only; federation is off).
matrix.jackalope.network {
	reverse_proxy synapse:8008
}

# Element Web client
element.jackalope.network {
	reverse_proxy element-web:80
}

# Ebooks: Calibre-Web (OPDS feed at /opds for iOS readers).
shelf.jackalope.network {
	reverse_proxy calibre-web:8083
}

# Audiobooks + podcasts: Audiobookshelf.
spokenword.jackalope.network {
	reverse_proxy audiobookshelf:80
}

# Document archive: Paperless-ngx.
cabinet.jackalope.network {
	reverse_proxy paperless:8000
}

# Container management UI: Portainer CE.
# Tailnet-only, never on Funnel. The Portainer agent has access to the
# Docker socket, so the auth boundary here is effectively "root on the box."
# See portainer/README.md for the full trust-boundary rationale.
portainer.jackalope.network {
	reverse_proxy portainer:9000
}

# ── Public photo sharing ─────────────────────────────────────────────────────
# Public photo sharing arrives via Tailscale Funnel. Funnel does TCP
# passthrough to local 443, so Caddy still terminates TLS with its
# own Let's Encrypt cert for photos.jackalope.network. See README
# bootstrap step 13 and docs/why-tailscale.md for the Funnel rationale
# and setup commands. Uncomment after Funnel is enabled.
#
# photos.jackalope.network {
# 	reverse_proxy immich_server:2283
# }
