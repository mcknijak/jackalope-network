# Secrets and per-host config
.env
*.env
!*.env.example
restic.env
secrets/
*.key
*.pem
*.crt
id_rsa*
id_ed25519*

# Server bind-mount safety: catch accidental /srv/<app>/data or
# /srv/<app>/volumes directories. Root-anchored and scoped to one
# level under /srv so this never matches source-code paths like
# welcome/src/data/.
/srv/*/data/
/srv/*/volumes/

# Editor / OS noise
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/
.idea/

# Caddy build artifacts (if anyone runs xcaddy locally)
caddy/caddy

# welcome page build output and node deps
welcome/dist/
welcome/node_modules/
welcome/.vite/
